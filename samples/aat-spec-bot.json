  "business_rules": [
    {
      "id": "rule-001",
      "name": "免费版成员上限",
      "description": "免费版最多支持10名团队成员，超出需升级付费计划",
      "rule_type": "authorization",
      "condition": "团队计划为免费版且成员数超过10",
      "expected_behavior": "禁止添加新成员，提示升级付费计划",
      "related_features": [
        "team/members",
        "team/billing"
      ]
    },
    {
      "id": "rule-002",
      "name": "站会创建必填项验证",
      "description": "创建站会时，站会名称、提醒时间、目标频道和模板字段为必填项",
      "rule_type": "validation",
      "condition": "用户提交创建站会表单时缺少必填项",
      "expected_behavior": "Bot返回错误提示，阻止表单提交",
      "related_features": [
        "standup/create"
      ]
    },
    {
      "id": "rule-003",
      "name": "异步站会提交时间窗口",
      "description": "团队成员可在配置的时间窗口内（如工作开始时）异步提交站会回答，Bot在指定时间汇总发布",
      "rule_type": "data_integrity",
      "condition": "用户提交站会回答的时间不在配置的时间窗口内",
      "expected_behavior": "Bot拒绝提交，提示用户在有效时间窗口内回答",
      "related_features": [
        "standup/config",
        "standup/report"
      ]
    },
    {
      "id": "rule-004",
      "name": "PM仪表盘数据访问权限",
      "description": "仅团队负责人/工程经理角色可访问PM仪表盘（含概览、团队健康度、阻塞项管理）",
      "rule_type": "authorization",
      "condition": "非团队负责人/工程经理角色用户尝试访问PM仪表盘",
      "expected_behavior": "拒绝访问，返回权限不足提示",
      "related_features": [
        "dashboard/overview",
        "dashboard/team-health",
        "dashboard/blockers"
      ]
    },
    {
      "id": "rule-005",
      "name": "阻塞项状态管理",
      "description": "阻塞项状态只能由报告人或有权限的管理员更新（如待解决、处理中、已解决）",
      "rule_type": "authorization",
      "condition": "非报告人或管理员尝试更新阻塞项状态",
      "expected_behavior": "拒绝操作，提示无权限",
      "related_features": [
        "dashboard/blockers"
      ]
    },
    {
      "id": "rule-006",
      "name": "免费版功能限制",
      "description": "免费版仅支持基础异步站会功能，PM仪表盘为付费版专属功能",
      "rule_type": "authorization",
      "condition": "免费版团队用户尝试访问PM仪表盘",
      "expected_behavior": "提示升级付费计划以解锁该功能",
      "related_features": [
        "dashboard/overview",
        "team/billing"
      ]
    }
  ]
}